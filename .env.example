# Example .env file for schema_matching project
# Copy this file to .env and fill in your actual API keys and settings

# Multiple LLM targets. Add/remove entries here to run many services at once.
# Providers: openai, google (Gemini via OpenAI-compatible API), deepseek, gemini_native
LLM_CLIENTS=deepseek_small_flash,deepseek_small_pro,google_small_lite,google_small_flash,openai_small_mini,openai_small_nano
LLM_STRUCTURED_OUTPUT=true

LLM_DEEPSEEK_SMALL_FLASH_NAME=deepseek_small
LLM_DEEPSEEK_SMALL_FLASH_PROVIDER=deepseek
LLM_DEEPSEEK_SMALL_FLASH_MODEL=deepseek-v4-flash
LLM_DEEPSEEK_SMALL_FLASH_API_KEY_ENV=DEEPSEEK_API_KEY
LLM_DEEPSEEK_SMALL_FLASH_BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK_SMALL_FLASH_USE_JSON_SCHEMA=false

LLM_DEEPSEEK_SMALL_PRO_NAME=deepseek_small
LLM_DEEPSEEK_SMALL_PRO_PROVIDER=deepseek
LLM_DEEPSEEK_SMALL_PRO_MODEL=deepseek-v4-pro
LLM_DEEPSEEK_SMALL_PRO_API_KEY_ENV=DEEPSEEK_API_KEY
LLM_DEEPSEEK_SMALL_PRO_BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK_SMALL_PRO_USE_JSON_SCHEMA=false

LLM_GOOGLE_SMALL_LITE_NAME=google_small
LLM_GOOGLE_SMALL_LITE_PROVIDER=google
LLM_GOOGLE_SMALL_LITE_MODEL=gemini-3.1-flash-lite
LLM_GOOGLE_SMALL_LITE_API_KEY_ENV=GEMINI_API_KEY
LLM_GOOGLE_SMALL_LITE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_GOOGLE_SMALL_LITE_USE_JSON_SCHEMA=true

LLM_GOOGLE_SMALL_FLASH_NAME=google_small
LLM_GOOGLE_SMALL_FLASH_PROVIDER=google
LLM_GOOGLE_SMALL_FLASH_MODEL=gemini-3.5-flash
LLM_GOOGLE_SMALL_FLASH_API_KEY_ENV=GEMINI_API_KEY
LLM_GOOGLE_SMALL_FLASH_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_GOOGLE_SMALL_FLASH_USE_JSON_SCHEMA=true

LLM_OPENAI_SMALL_MINI_NAME=openai_small
LLM_OPENAI_SMALL_MINI_PROVIDER=openai
LLM_OPENAI_SMALL_MINI_MODEL=gpt-5.4-mini
LLM_OPENAI_SMALL_MINI_API_KEY_ENV=OPENAI_API_KEY
LLM_OPENAI_SMALL_MINI_USE_JSON_SCHEMA=true

LLM_OPENAI_SMALL_NANO_NAME=openai_small
LLM_OPENAI_SMALL_NANO_PROVIDER=openai
LLM_OPENAI_SMALL_NANO_MODEL=gpt-5.4-nano
LLM_OPENAI_SMALL_NANO_API_KEY_ENV=OPENAI_API_KEY
LLM_OPENAI_SMALL_NANO_USE_JSON_SCHEMA=true

# API keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI PARSE API
OPENAI_PARSE_JSON_API_KEY=your_openai_parse_json_api_key_here
OPENAI_PARSE_JSON_MODEL_NAME=gpt-5.4-nano

# Request rate per second
LLM_REQUESTS_PER_SECOND=250
